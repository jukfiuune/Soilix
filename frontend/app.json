{
  "expo": {
    "name": "Soilix",
    "slug": "soilix",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#eefbf3",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#eefbf3"
      },
      "package": "com.soilix.app",
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Soilix to access your camera to scan device QR codes."
        }
      ]
    ]
  }
}
